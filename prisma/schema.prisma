datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id                 String   @id
  name               String   @unique
  gender             String
  gender_probability Float
  sample_size        Int
  age                Int
  age_group          String
  country_id         String
  country_probability Float
  created_at         DateTime @default(now())
}
